<Window x:Class="TeamsPresenceBridge.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LED Color Settings"
        Width="420" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FF1E1E1E">

    <Window.Resources>
        <!-- Label text -->
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Small pick-color button -->
        <Style TargetType="Button" x:Key="PickBtn">
            <Setter Property="Background" Value="#FF3C3C3C"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF4E4E52"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF2A2A2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bottom action button (Defaults / Cancel) -->
        <Style TargetType="Button" x:Key="ActionBtn" BasedOn="{StaticResource PickBtn}">
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>

        <!-- Primary action button (Save) -->
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Background" Value="#FF0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF005A9E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1A8AD4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="20">
        <!-- Header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="LED Color Settings"
                   FontSize="20" FontWeight="SemiBold"
                   Foreground="White"
                   FontFamily="Segoe UI"
                   Margin="0,0,0,4"/>
        <TextBlock DockPanel.Dock="Top"
                   Text="Pick a color for each Teams presence state"
                   FontSize="12"
                   Foreground="#FF888888"
                   FontFamily="Segoe UI"
                   Margin="0,0,0,16"/>

        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Defaults" Style="{StaticResource ActionBtn}" Click="OnDefaults" Margin="0,0,8,0"/>
            <Button Content="Save"     Style="{StaticResource PrimaryBtn}" Click="OnSave"    Margin="0,0,8,0"/>
            <Button Content="Cancel"   Style="{StaticResource ActionBtn}" Click="OnCancel"/>
        </StackPanel>

        <!-- Thin separator above the buttons -->
        <Border DockPanel.Dock="Bottom" Height="1" Background="#FF333333" Margin="0,8,0,0"/>

        <!-- Color entry rows -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ColorList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,2" Padding="8,6" CornerRadius="4" Background="#FF2A2A2E">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding DisplayName}"
                                           Style="{StaticResource LabelStyle}"/>

                                <Border Grid.Column="1" Width="28" Height="28"
                                        CornerRadius="4"
                                        BorderBrush="#FF555555" BorderThickness="1"
                                        Background="{Binding ColorBrush}"/>

                                <Button Grid.Column="2" Content="Pick Color…"
                                        Style="{StaticResource PickBtn}"
                                        HorizontalAlignment="Left" Margin="8,0,0,0"
                                        Tag="{Binding}" Click="OnPickColor"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
