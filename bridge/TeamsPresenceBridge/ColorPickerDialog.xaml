<Window x:Class="TeamsPresenceBridge.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick a Color"
        Width="320" Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#FF1E1E1E">

    <Window.Resources>
        <!-- Slider style for the RGB channels -->
        <Style TargetType="Slider" x:Key="ChannelSlider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="255"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="16"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="Value">
            <Setter Property="Foreground" Value="#FF999999"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>

        <!-- Button styles -->
        <Style TargetType="Button" x:Key="DialogBtn">
            <Setter Property="Background" Value="#FF3C3C3C"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF4E4E52"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="OkBtn" BasedOn="{StaticResource DialogBtn}">
            <Setter Property="Background" Value="#FF0078D4"/>
            <Setter Property="BorderBrush" Value="#FF005A9E"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <!-- Color preview -->
        <Border DockPanel.Dock="Top" Height="48" CornerRadius="4"
                BorderBrush="#FF555555" BorderThickness="1" Margin="0,0,0,16"
                x:Name="PreviewBorder"/>

        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK"     Style="{StaticResource OkBtn}"     Click="OnOk"     Margin="0,0,8,0"/>
            <Button Content="Cancel" Style="{StaticResource DialogBtn}" Click="OnCancel"/>
        </StackPanel>

        <!-- RGB sliders -->
        <StackPanel>
            <!-- Red -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="R" Style="{StaticResource Label}" Foreground="#FFE06060"/>
                <Slider Grid.Column="1" Style="{StaticResource ChannelSlider}" Margin="8,0"
                        x:Name="SliderR" ValueChanged="OnSliderChanged"/>
                <TextBlock Grid.Column="2" Style="{StaticResource Value}" x:Name="ValueR"/>
            </Grid>

            <!-- Green -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="G" Style="{StaticResource Label}" Foreground="#FF60E060"/>
                <Slider Grid.Column="1" Style="{StaticResource ChannelSlider}" Margin="8,0"
                        x:Name="SliderG" ValueChanged="OnSliderChanged"/>
                <TextBlock Grid.Column="2" Style="{StaticResource Value}" x:Name="ValueG"/>
            </Grid>

            <!-- Blue -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="B" Style="{StaticResource Label}" Foreground="#FF6060E0"/>
                <Slider Grid.Column="1" Style="{StaticResource ChannelSlider}" Margin="8,0"
                        x:Name="SliderB" ValueChanged="OnSliderChanged"/>
                <TextBlock Grid.Column="2" Style="{StaticResource Value}" x:Name="ValueB"/>
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
